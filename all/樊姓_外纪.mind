t":null},"children":[{"data":{"id":"djljoy1x5lk0","created":1782737475355,"text":"尚","note":"嗣候","layout":null},"children":[]}]}]}]},{"data":{"id":"djljjmd59b40","created":1782737058092,"text":"郴","layout":null},"children":[]},{"data":{"id":"djljjn2jy200","created":1782737059628,"text":"梵","note":"鸿胪卿","layout":null},"children":[]}]},{"data":{"id":"djlji4c0ne00","created":1782736940477,"text":"鮪","layout":null},"children":[]},{"data":{"id":"djlji4t7prc0","created":1782736941517,"text":"茂","note":"平望候","layout":null},"children":[]}]},{"data":{"id":"djljby70b740","created":1782736456929,"text":"真","layout":null},"children":[{"data":{"id":"djljg6fv8k80","created":1782736788335,"text":"寻","note":"元乡候","layout":null,"expandState":"collapse"},"children":[{"data":{"id":"djljgd17c9s0","created":1782736802686,"text":"元","note":"都尉","layout":null},"children":[]},{"data":{"id":"djljgp74sm80","created":1782736829166,"text":"明","note":"散骑常侍","layout":null},"children":[{"data":{"id":"djljh19wki00","created":1782736855455,"text":"肃","layout":null},"children":[{"data":{"id":"djljh40vl5s0","created":1782736861439,"text":"英","note":"字季齐\n顺帝徽为师","layout":null},"children":[]}]}]}]},{"data":{"id":"djljg9he7ts0","created":1782736794958,"text":"候","layout":null},"children":[]}]}]},{"data":{"id":"djljas4wbls0","created":1782736365376,"text":"彝","layout":null},"children":[]},{"data":{"id":"djljahbnep40","created":1782736341840,"text":"章","note":"元始二年封舞阳侯 邑千户","layout":null},"children":[]}]}]},{"data":{"id":"djkr4l4n2iw0","created":1782656888861,"text":"型","layout":null},"children":[]},{"data":{"id":"djkr4iaiq5s0","created":1782656882686,"text":"胜","note":"元康四年诏復家","layout":null},"children":[]}]}]}]}]},{"data":{"id":"djkqtlh0cpk0","created":1782656027603,"text":"權","layout":null},"children":[]}]},{"data":{"id":"djkqpickwp40","created":1782655707348,"text":"濬","layout":null},"children":[{"data":{"id":"djkqpt8zrhs0","created":1782655731076,"text":"琅","note":" 仕泰为都尉","layout":null},"children":[{"data":{"id":"djkqs8arwpc0","created":1782655920564,"text":"简","layout":null},"children":[{"data":{"id":"djkqs9cw26o0","created":1782655922868,"text":"洪","layout":null},"children":[{"data":{"id":"djkqsa9ykyg0","created":1782655924868,"text":"药","layout":null},"children":[{"data":{"id":"djkquohjyow0","created":1782656112530,"text":"樊哙","hyperlink":null,"hyperlinkTitle":null,"note":"赐号贤成\n汉封舞阳侯\n谥武候\n娶吕氏高后女弟临光侯","layout":null},"children":[{"data":{"id":"djmbxxai9qg0","created":1782817170052,"text":"市人","note":"兄伉失候文帝立復书爵\n\n樊噲 百度百科：\n樊伉被杀後。舞阳侯中绝数月。 [59]庶出的樊市人后来继承了舞阳侯，恢复了原来的爵位和食邑。樊市人在位二十九年死去，谥号为荒侯。","layout":null},"children":[{"data":{"id":"djmc4lvoof40","created":1782817693761,"text":"他廣","note":"\n\n樊噲 百度百科：\n继承了舞阳侯的爵位，但是舞阳侯家的舍人得罪樊他广，被樊他广处罚，心生怨恨，于是上书秘密禀报汉景帝说：“荒侯樊市人其实有不能人道的隐疾，樊他广不是樊市人的儿子，是樊市人命令自己的妻子与樊市人的弟弟所生下的孩子，因此樊他广应该没有继承樊市人爵位的资格。”公元前143年，第四代武阳侯樊他广 “被夺侯为庶人，国除。”","layout":null},"children":[{"data":{"id":"djmc63ugkr40","created":1782817811233,"text":"胜客","layout":null},"children":[{"data":{"id":"djmc676b91k0","created":1782817818480,"text":"？","layout":null},"children":[{"data":{"id":"djmc68a9n5c0","created":1782817820896,"text":"章","note":"樊噲玄孫之子章\n汉平帝时绍封舞阳侯，食邑千户\n\n\n樊章 百度百科：\n樊章，西汉名将樊哙五世孙（玄孙之子）。汉平帝时，继绝世。樊章作为樊哙玄孙之子被汉平帝绍封为舞阳侯，食邑千户。","layout":null},"children":[]}]}]}]}]},{"data":{"id":"djkquqvwm1c0","created":1782656117752,"text":"樊伉","note":"嗣封舞阳侯\n\n以下來自百科 樊噲\n嫡出的樊伉，诸吕之乱后大臣们诛杀吕氏宗族和吕媭的亲属，樊伉被杀","layout":null},"children":[]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]}]},{"data":{"id":"djmeqofl4mw0","created":1782825065549,"text":"次子在周为官","layout":null},"children":[]},{"data":{"id":"djmeq3uvj0o0","created":1782825020761,"text":"长子继嗣为君","layout":null},"children":[]}]},"template":"structure","theme":"fresh-blue","version":"1.4.43"}